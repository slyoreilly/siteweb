# Exemple de configuration sync inbound

# Inbound (aval -> amont)
WORK_ENV=development
SYNC_INBOUND_TOKEN=change-me-dev

# ACK sortant (amont -> aval)
SYNC_ACK_URL=https://aval.exemple.com/api/sync/ack
SYNC_ACK_TOKEN=change-me-ack
SYNC_ACK_HEADER=X-Sync-Token
SYNC_ACK_TIMEOUT_SECONDS=8
SYNC_ACK_MAX_ATTEMPTS=6

# Prod
# WORK_ENV=production
# SYNC_INBOUND_TOKEN=<token-fort-inbound>
# SYNC_ACK_URL=https://<AVAL>/api/sync/ack
# SYNC_ACK_TOKEN=<token-fort-ack>
# SYNC_ACK_HEADER=X-Sync-Token
# SYNC_ACK_TIMEOUT_SECONDS=8
# SYNC_ACK_MAX_ATTEMPTS=6
