			function afficheTabVent(rJSON) {

				div1 = document.getElementById('idTabVent');
				tabVent = document.createElement('TABLE');
				tabVent.className = 'c_tableau';
				tabVent.id = 'tab_tabVent';
				tBodyVent = document.createElement('TBODY');
				trTitreVent = document.createElement('TR');
				trTitreVent.id = 'trTitreVent';
				trTitreVent.className = 'rangeeTitre rangeeTitreSommaire';
				trDomVent = document.createElement('TR');
				trDomVent.className = 'lignePaire';
				trDomVent.id = 'trDomVent';
				trVisVent = document.createElement('TR');
				trVisVent.id = 'trVisVent';
				trVisVent.className = 'ligneImpaire';
				tdRTVent = document.createElement('TD');
				tdRTVent.id = 'tdTitreTableauFus';
				tdRTVent.className = 'titreTableau';
				tdRTVent.innerHTML = window.tl_resultats_Sommaire;
				tdRTVent.colSpan = 4;
				trRTVent = document.createElement('TR');
				trRTVent.id = 'trTitreTableauFus';
				trRTVent.className = 'titreTableau';

				tdTitreVent = document.createElement('TD');
				tdTitreVent.id = 'tdTitreVent';
				tdTitreVent.innerHTML = window.tl_match_Equipe;
				tdEqDomVent = document.createElement('TD');
				tdEqDomVent.id = 'tdEqDomVent';
				tdEqDomVent.innerHTML = rJSON.eqDom;
				tdEqVisVent = document.createElement('TD');
				tdEqVisVent.id = 'tdEqVisVent';
				tdEqVisVent.innerHTML = rJSON.eqVis;

				tabVent.appendChild(tBodyVent);
				trRTVent.appendChild(tdRTVent);
				tBodyVent.appendChild(trRTVent);

				tBodyVent.appendChild(trTitreVent);
				tBodyVent.appendChild(trDomVent);
				tBodyVent.appendChild(trVisVent);
				trTitreVent.appendChild(tdTitreVent);
				trDomVent.appendChild(tdEqDomVent);
				trVisVent.appendChild(tdEqVisVent);

				div1.appendChild(tabVent);

				try {
					var scoreDom = 0;
					var scoreVis = 0;

					//rJSON.periodes.shift();
					try {
						maPer = rJSON.periodes[0];
					} catch(err) {
						console.log(err.message + "Erreur vent");
					}
					var Iper = 0;
					for ( J = 0; J < rJSON.buts.length; J = J + 1) {
						trouve = false;
						while (!trouve) {
							if (rJSON.periodes.length > 0 && Iper < rJSON.periodes.length) {

								try {

									if (parseInt(rJSON.periodes[Iper].chrono) < parseInt(rJSON.buts[J].chrono)) {
										//					maPer = rJSON.periodes.shift();
										while (parseInt(rJSON.periodes[Iper].chrono) < parseInt(rJSON.buts[J].chrono) && Iper < rJSON.periodes.length) {
											maPer = rJSON.periodes[Iper];
											Iper++;
											//										$('trTitreVent').append('<td>'+maPer.numero+'</td>')
											tdTitrePer = document.createElement('TD');
											tdTitrePer.innerHTML = maPer.numero;
											document.getElementById('trTitreVent').appendChild(tdTitrePer);

											tdDomPer = document.createElement('TD');
											tdDomPer.innerHTML = 0;
											document.getElementById('trDomVent').appendChild(tdDomPer);
											tdVisPer = document.createElement('TD');
											tdVisPer.innerHTML = 0;
											document.getElementById('trVisVent').appendChild(tdVisPer);
										}

									} else {
										if (J == 0) {
											tdTitrePer = document.createElement('TD');
											tdTitrePer.innerHTML = 0;
											document.getElementById('trTitreVent').appendChild(tdTitrePer);

											tdDomPer = document.createElement('TD');
											tdDomPer.innerHTML = 0;
											document.getElementById('trDomVent').appendChild(tdDomPer);
											tdVisPer = document.createElement('TD');
											tdVisPer.innerHTML = 0;
											document.getElementById('trVisVent').appendChild(tdVisPer);
										}
									}

								} catch(err) {
									if (Iper == 0) {
										tdTitrePer = document.createElement('TD');
										tdTitrePer.innerHTML = 0;
										document.getElementById('trTitreVent').appendChild(tdTitrePer);

										tdDomPer = document.createElement('TD');
										tdDomPer.innerHTML = 0;
										document.getElementById('trDomVent').appendChild(tdDomPer);
										tdVisPer = document.createElement('TD');
										tdVisPer.innerHTML = 0;
										document.getElementById('trVisVent').appendChild(tdVisPer);
										Iper++;
									}
									if (vPerm < 10) {
										//	console.log(err.message + " erreur vent 3, per "+Iper);
									}

								}
							} else {
								if (Iper == 0) {
									tdTitrePer = document.createElement('TD');
									tdTitrePer.innerHTML = 0;
									document.getElementById('trTitreVent').appendChild(tdTitrePer);

									tdDomPer = document.createElement('TD');
									tdDomPer.innerHTML = 0;
									document.getElementById('trDomVent').appendChild(tdDomPer);
									tdVisPer = document.createElement('TD');
									tdVisPer.innerHTML = 0;
									document.getElementById('trVisVent').appendChild(tdVisPer);
									Iper++;
								}

							}
							if (rJSON.buts[J].equipe == rJSON.eqDom) {
								tdDomPer.innerHTML = parseInt(tdDomPer.innerHTML) + 1;
								scoreDom++;
								trouve = true;
							}
							if (rJSON.buts[J].equipe == rJSON.eqVis) {
								tdVisPer.innerHTML = parseInt(tdVisPer.innerHTML) + 1;
								scoreVis++;
								trouve = true;
							}
						}//fin while(!trouve)
					}// fin du for
					tdTitrePer = document.createElement('TD');
					tdTitrePer.innerHTML = "F";
					document.getElementById('trTitreVent').appendChild(tdTitrePer);

					tdDomPer = document.createElement('TD');
					tdDomPer.innerHTML = scoreDom;
					document.getElementById('trDomVent').appendChild(tdDomPer);
					tdVisPer = document.createElement('TD');
					tdVisPer.innerHTML = scoreVis;
					document.getElementById('trVisVent').appendChild(tdVisPer);

				}

				//	document.body.rangee.cellule.innerHTML ='yo';
				catch(err) {
				   
					if (vPerm < 10) {
						console.log(err.message + " erreur vent 2");
					}
				}


			}

