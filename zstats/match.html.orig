				$('.erreur').parent().css('background', '#000');

				if (mBut != "") {

					place = mBut.video[vidIndex].emplacement;
					if (place == null || !strcmp(place, "")) {
						place = "syncstats.com";
					}
					mVid = "http://" + place + "/lookatthis/" + mBut.video[vidIndex].fic;
					//titreCam
					$('#modalVideoBut .modal-title').text("Cam "+mBut.video[vidIndex].cam);
					
					//console.log(mVid);
					$('#vidPrincId').attr("src", mVid);
					$('#parent-erreur').remove();
					//$('#vidPrincId')  .error(function() {
					//$( this ).before($('<img></img>').attr("src", "/images/icones/warning.png" ));
					//	 })
					//	 .attr( "src", mVid );

					for ( a = 0; a < mBut.video.length; a++) {
						if (a == vidIndex) {
							if (strcmp(mBut.video[a].etat, "archive") == 0) {
								$('#vidPrincId').parent().before($('<div id="parent-erreur"></div>').append($('<p class="erreur"></p>').text("This video has been put in the archive. It can be automaticaly restored in 24h if you wish to proceed.")).append($('<input type="button" value="Proceed?"></input>').click({
									videoId : vidsAlt.video[a].videoId,
									fic : mBut.video[a].fic
								}, function(event) {
									$.post("../scriptserveur/demandeRestoreVideo.php", {
										videoId : event.data.videoId,
										fic : event.data.fic
									}, "json").done(function(data) {
										//console.log(data);
										retour = eval('(' + data + ')');
										if (parseInt(retour.succes) == 1) {
											console.log("La demande a été envoyée");
										}
										if (parseInt(retour.succes) == 0) {
											console.log("Une erreur s'est produite");
										}

									});
								})).append($('<img ></img>').attr("src", "/images/icones/Icon-Archive.png").css("width", "50px").css("width", "50px")));
								//$( this ).unbind("error");

								$('.play-pause').addClass('play').removeClass('pause');
							} else {
								document.getElementById('vidPrincId').addEventListener('error', function(event) {
									if ($('.erreur').length < 2) {
										$(this).parent().before($('<div id="parent-erreur"></div>').append($('<p class="erreur"></p>').text("There is an error with this video, please go to the next one (and sorry, btw...)")).append($('<img ></img>').attr("src", "/images/icones/warning.png").css("width", "50px").css("width", "50px")));
										//$( this ).unbind("error");
										$('.play-pause').addClass('play').removeClass('pause');
									}
									//console.log("There's an error with this video, please go to the next one (and sorry, btw...)")
								}, true);

							}

						}

					}

					logoOverride = true;
					logoOverrideLoc = document.location.href + "&videofile=" + encodeURIComponent(mBut.video[vidIndex].fic);
					//+"&but="+encodeURIComponent(mBut);
					logoOverrideT = "Vidéo";

				} else {
					place = "5.39.81.14";
					mVid = "http://" + place + "/lookatthis/" + getValue('videofile');
					//console.log(mVid);
					$('#vidPrincId').attr("src", mVid);
					$('#parent-erreur').remove();

				}

				/*
