					opt.setAttribute("selected", "true");
				opt2 = document.createElement('OPTION');
				opt2.innerHTML = "- " + window.tl_match_aucun + " -";
				$(opt2).val("0");
				if (!trouveP1)
					opt2.setAttribute("selected", "true");
				
				opt3 = document.createElement('OPTION');
				opt3.innerHTML = "- " + window.window.tl_match_aucun + " -";
                $(opt3).val("0");
				if (!trouveP2)
					opt3.setAttribute("selected", "true");
				
				$(selMarq).append($(opt));
                    $(selPass1).append($(opt2));
                    $(selPass2).append($(opt3));

$(doc).append(
    $('<div></div>').addClass("row m-4").append(
        $('<div></div>').addClass("col-4").text(window.tl_match_Marqueur),$('<div></div>').addClass("col-4").text(window.tl_match_Passe1),$('<div></div>').addClass("col-4").text(window.tl_match_Passe2)
   
