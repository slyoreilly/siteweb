                    	if (lequipe.joueurs[a].joueurId == window.rJSON.buts[but].passeur2Id) {
						$(opt3).prop("selected", "true");
						trouveP2 = 1;
					}
					//console.log("Joueur: "+statsJSONHome.joueurs[a].nom);
					$(selMarq).append($(opt));
					$(selPass1).append($(opt2));
					$(selPass2).append($(opt3));
				}
				//	lequipe.joueurs.push(null);
				opt = document.createElement('OPTION');
				opt.innerHTML = "- " + window.tl_match_aucun + " (Delete goal)- ";
                $(opt).val("0");
