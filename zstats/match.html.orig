				 } catch(err) {
				 }
				 $('.media-box').hide();
				 $(".play-btn").show();
				 $('.play-pause').addClass('play').removeClass('pause');

				 });
				 }*/

				var requete_ajax = new XMLHttpRequest();
				var url = "/scriptsphp/getVideoUnique.php";
				var pVF = String(mBut.video[vidIndex].fic);

				var sVF = pVF.split(".");
				var strVid = "videofile=" + sVF[0];
				params = strVid;
				url = url + "?" + params;
				requete_ajax.open('POST', url, true);
				requete_ajax.setRequestHeader("Content-type", "application/x-www-form-urlencoded;charset=utf-8");
				requete_ajax.send(params);
				if (mBut != undefined && mBut != "") {
					chargeListeCote(vidIndex, mBut);
				}
				requete_ajax.onreadystatechange = function() {
					if (requete_ajax.readyState == 4 && requete_ajax.status == 200) {

						infoVid = eval('(' + requete_ajax.responseText + ')');
						$('#rateSpan').text("RATING: " + infoVid.eval + " / 5");
						if(parseInt(infoVid.nbVues)>=5){
                        $('#nbVuesSpan').text("Vue " + infoVid.nbVues + " fois");
						}
						$('.video-info p').text("Marqueur: " + infoVid.NomJoueur);
						if(vPerm<15){
						    $('#video-info input').remove();
						    $('#video-info').append($("<input></input>").attr("type","button").val("Effacer ce video").on("click",{fic:mBut.video[vidIndex].fic} ,function(event){
						      $.ajax({
                                        url : "/scriptsphp/effaceVideo.php",
                                        type : "POST",
                                        data : {
                                            fic : fic
                                        },
                                        dataType : "html",
                                        success : function(response) {
                                            
                                            
                                        }
						    });
						    }));
						}
						evalBut = getCookie('videoId_eval_' + infoVid.videoId);
						console.log("evalBut: "+evalBut);
						if (evalBut != null) {
							$('#rating-star').raty({
								score : evalBut
							});
						} else {
							$('#rating-star').raty({
								click : function(score, evt) {
								    console.log("click Raty");
									$.post('/scriptsphp/evalueVid.php', {
										videoId : infoVid.videoId,
										evalBut : score
									});
									setCookie('videoId_eval_' + infoVid.videoId, score, 1000);
								}
							});

						}

						//$('#video-info').append($('<div></div>').text('TEST!'));//.append($('<ins></ins>').addClass('adsbygoogle')));
						$('#pub-google').append($('<ins></ins>').addClass('adsbygoogle').css("display", "inline-block").css("width", "234px").css("height", "60px").attr("data-ad-slot", "9551625935").attr("data-ad-client", "ca-pub-2263794877114969"));

						//console.log(vidIndex);
						vidSuite(vidIndex, mBut);
						//console.log(vidIndex);
						try {
						$('ins').each(function() {
							( adsbygoogle = window.adsbygoogle || []).push({});
						});
						}
                        catch(err) {
                            console.log(err.message);
                        }
						//(adsbygoogle = window.adsbygoogle || []).push({});

						$.post('/scriptsphp/incrementeVidNbVues.php', {
							videoId : infoVid.videoId
						});
						$('#drapeauVert').click(function() {
							$.post('/scriptsphp/changeAngleOk.php', {
