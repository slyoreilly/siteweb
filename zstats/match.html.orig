			function affichePlusHighlights(rSMB) {
				var lesTitres = new Array();

				lesTitres[0] = window.tl_match_Chrono;
				lesTitres[1] = "";
				div1 = document.getElementById('tabButs');

				//  lecorps = document.getElementById('divCentrale');
				table1 = document.createElement('TABLE');
				table1.id = "tableHighlights";
				table1.className = "c_tableau";
				tb = document.createElement('TBODY');
				tb.id = "bodyTable";
				tr1 = document.createElement('TR');
				tr1.id = "rangeeHeaderHighlights";
				td1 = document.createElement('TD');
				td1.className = "titreTableau";
				td1.colSpan = lesTitres.length;
				td1.innerHTML = "More Highlights";
				tr2 = document.createElement('TR');
				tr2.id = "rangeeTitreHighlights";

				for ( i = 0; i < lesTitres.length; i++) {
					tdi = document.createElement('TD');
					tdi.className = "rangeeTitre";
					tdi.innerHTML = lesTitres[i];
					tr2.appendChild(tdi);
				}

				tr1.appendChild(td1);
				tb.appendChild(tr1);
				tb.appendChild(tr2);
				table1.appendChild(tb);
				div1.appendChild(table1);
				//lecorps.appendChild(div1);
				//lecorps.appendChild(frameModif);

				/////////////////////////////////////////////////////////////

				////////////////////////////////////////////////////////////

				try
				{

					maPer = new Array();
					//rSMB.periodes.shift();

					if (rSMB.periodes.length > 0)
						maPer = rSMB.periodes[0];
					else {
						if (rSMB.clips.length > 0) {
							maPer.chrono = rSMB.clips[0].chrono;

						} else {
							if (rSMB.buts.length > 0) {
								maPer.chrono = rSMB.buts[0].chrono;

							} else {
								maPer.chrono = 0;
							}

						}

					}
					var Iper = 0;
					for (var J = 0; J < rSMB.clips.length; J = J + 1) {
						//                      try {
						var perStop = false;
						if (rSMB.periodes.length > 0) {
							//if (parseInt(rSMB.periodes[Iper].chrono) < parseInt(rSMB.buts[J].chrono)) {
							while (Iper < rSMB.periodes.length && !perStop) {
								//                  maPer = rSMB.periodes.shift();

								//   console.log(parseInt(rSMB.periodes[Iper].chrono)-parseInt(rSMB.buts[J].chrono)+" , Iper: "+Iper+", J: "+J);

								if (parseInt(rSMB.periodes[Iper].chrono) < parseInt(rSMB.clips[J].chrono)) {
									maPer = rSMB.periodes[Iper];

									$('#rangeeTitreHighlights').parent().append($('<TR></TR>').addClass("periode").append($('<TD></TD>').attr("colSpan", "5").addClass("rangeeTitre periode").text(window.tl_match_periode + " " + maPer.numero)));
									//									amettrePer = document.getElementById('rangeeTitreHighlights');
									//								amettrePer.parentNode.appendChild(rangeePer);
									//									cPer = document.createElement('TD');
									//									cPer.setAttribute("colSpan", "2")
									//									cPer.setAttribute("class", "rangeeTitre")
									//									tPer = document.createTextNode();
									//									cPer.appendChild(tPer);
									//									rangeePer.appendChild(cPer);
									Iper++;
									if (Iper < rSMB.periodes.length) {
										if (parseInt(rSMB.periodes[Iper].chrono) > parseInt(rSMB.clips[J].chrono)) {
											perStop = true;
										}
									} else {

										perStop = true;
									}

								} else {
									perStop = true;
								}

							}

							//                              }
						}// Fin du S'il y a des périodes
						//                      } catch(err) {
						//                      }

						//  if(!statsJSON.joueurs[J].nom.isNull&&statsJSON.joueurs[J].nom!='Anonyme')
						rangee = document.createElement('TR');
						amettre = document.getElementById('rangeeTitreHighlights');
						amettre.parentNode.appendChild(rangee);
						minutes = Math.floor((parseInt(rSMB.clips[J].chrono) - parseInt(maPer.chrono)) / 60000);
						//  console.log("minutes"+minutes+" ");
						dizSecondes = Math.floor(((parseInt(rSMB.clips[J].chrono) - parseInt(maPer.chrono)) - minutes * 60000) / 10000);
						secondes = Math.floor(((parseInt(rSMB.clips[J].chrono) - parseInt(maPer.chrono)) - minutes * 60000 - dizSecondes * 10000) / 1000);
						//  console.log("secondes"+secondes+" ");
						strChrono = minutes + ":" + dizSecondes + secondes;

						var lesCols = new Array();
						//
						//console.log('mSrc');
						//console.log(mSrc);
						//console.log(rSMB.buts[J].equipe);
						//
						lesCols[0] = strChrono;
						lesCols[1] = "";

						//          console.log(rSMB.buts[J].video.length);
						//          lesCols[6] = (rSMB.buts[J].video.length <= 0) ? "" : "Voir";

						if (rSMB.clips.length > 0) {
							try {

								var mBut = rSMB.clips[J];
								strV = mBut;
								pVids = document.createElement('A');
								//          pVids[a].innerHTML= UrlExists("../lookatthis/" + strV.fic)?" Cam  "+b+" ":"";
								imgVid = document.createElement('IMG');
								imgVid.src = "/images/icones/movie.png";
								imgVid.alt = "Video";

								/*$(imgVid).hover(function(){
								 $(this).attr('src','/images/icones/movie.ico');
								 },function(){
								 $(this).attr('src','/images/icones/movie.ico');
								 });*/
								if (mBut != null) {
									if (mBut.video.length > 0) {
										pVids.appendChild(imgVid);
										//              pVids.innerHTML= " Video Replay ";
										pVids.id = "../lookatthis/" + mBut.fic;
										pVids.className = "cliquable";
										pVids.onclick = (function(mBut) {
											return function() {
												//                  window.location="../lookatthis/" + strV.fic;
												$("#contVids").empty();
												construitVid();
												//console.log("Construit vids clips");
												vidIndex = 0;

												strV = mBut.video[vidIndex];
												/*monOverlay = document.createElement('DIV');
												monOverlay.id = "ecranSombre";
												document.getElementsByTagName('BODY')[0].appendChild(monOverlay);*/
												$('.media-box').show();
												place = mBut.video[0].emplacement;
												if (place == null || !strcmp(place, "")) {
													place = "syncstats.com";
												}
												document.getElementsByTagName('SOURCE')[0].src = "http://" + place + "/lookatthis/" + mBut.video[0].fic;
												document.getElementsByTagName('SOURCE')[0].type = "video/mp4";
												$('#divCentrale').append($('#contVids').addClass("divDialogue").addClass("visible").css({
													"opacity" : "1",
													"position" : "fixed",
													"left" : "100px",
													"top" : "100px",
													"z-index" : "2000"
												}));

												getInfoVid(vidIndex, mBut);

											};
										})(mBut);
									}
								}
								var lesLiens = new Array();
								lesLiens[0] = null;
								lesLiens[1] = null;

								for ( K = 0; K < lesCols.length; K++) {
									// console.log(K);
									cellule = document.createElement('TD');
									if (lesCols[K] != undefined) {
										if (lesLiens[K] != null) {
											//console.log("should not");
											lien = document.createElement('A');
											lien.innerHTML = lesCols[K];
											lien.href = lesLiens[K];
											cellule.appendChild(lien);
										} else {
											//          console.log(K );

											if (K == 1) {
												//  console.log('Ss');
												cellule.appendChild(pVids);
												//console.log(pVids.id);
											} else {
												ptexte = document.createElement('P');

												ptexte.innerHTML = lesCols[K];
												//                  texte = document.createTextNode(lesCols[K]);
												cellule.appendChild(ptexte);
											}
										}
									}
									rangee.appendChild(cellule);
								}
								J % 2 == 0 ? rangee.className = 'lignePaire' : rangee.className = 'ligneImpaire';
							} catch(err) {
								if (vPerm < 10) {
									console.log("console.loge admin: Pas réussi à afficher le vidéo");
								}
							}
						}// Fin du If video

					}

					//  document.body.rangee.cellule.innerHTML ='yo';
				} catch(err) {
					console.log(err.message + "\n console.loge admin: Pas réussi à faire la table more highlights");
				}

			}

