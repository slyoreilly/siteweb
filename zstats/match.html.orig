					 }).append('<h3></h3>').text(' < Cacher < '),*/
					$('<ul id="play-list"></ul>'));

					for (var a = 0; a < mBut.video.length; a++) {
						place = mBut.video[a].emplacement;
						if (place == null || !strcmp(place, "")) {
							place = "syncstats.com";
						}
						mVid = "http://" + place + "/lookatthis/" + mBut.video[vidIndex].fic;
						//console.log(vidsAlt.video[a].fic);
						strThumb = "/images/icones/movie.png";
						if (mBut.video[a].thumbnail != null) {
							strThumb = "http://" + place + "/thumbnails/" + mBut.video[a].thumbnail;
						}
