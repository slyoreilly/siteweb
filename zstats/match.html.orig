						// $('<video></video>').addClass('play-item').attr('src',vidsAlt.video[a].fic),
						$('<div></div>').addClass('thumbnail-wrap').append(/*$('<span></span>').addClass('thumbnail-title').text(vidsAlt.video[a].cam),*/
						$('<br />'), $('<span></span>').addClass('thumbnail-content').text("Cam " + vidsAlt.video[a].cam), $('<img></img>').addClass('thumbnail-content').attr("src", strThumb).attr("alt", "Video"))).on("click"
						,
						{
							vids : a,
							but : mBut
						},
						 function(event) {console.log("click thumbnail");
							getInfoVid(event.data.vids, event.data.but);
						}
						)
						//.click(loadVideo(vidsAlt.video[a].fic))
						);
					}
					$('#media-play-list').show();

				}

			}

			function vidSuite(vidIndex, mBut) {

				vidSVC = document.getElementById('media-video');
				vidSVC.style.display = "block";
				vidSVC.load();

				rang = 0;
				//    console.log(document.getElementById('divCentrale'));
