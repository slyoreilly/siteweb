			function ajouteJoueur(domvis, souscode) {

				if (domvis == 1) {

					$('#boiteSelectDom').empty();
					$('#boiteSelectDom').append($('<div id="boiteResRecherchePres"></div>').css("position", "relative").css("text-align", "left").css("background-color", "white"));
					equipeId = window.rJSON.eqDomId;
				} else {
					$('#boiteSelectVis').empty();
					$('#boiteSelectVis').append($('<div id="boiteResRecherchePres"></div>').css("position", "relative").css("text-align", "left").css("background-color", "white"));
					equipeId = window.rJSON.eqVisId;
				}

				if (window.lesJoueursDeLigue != null) {
					str = $('#boiteRecherchePresence').val().toLowerCase();
					//console.log(str);
					for (var b = 0; b < window.lesJoueursDeLigue.equipe.length; b++) {
						//  console.log(JSON.stringify(window.lesJoueursDeLigue.equipe[b]));
						for (var a = 0; a < window.lesJoueursDeLigue.equipe[b].joueur.length; a++) {
							//console.log(window.lesJoueursDeLigue.equipe[b].joueur[a].nomJoueur);
							//console.log(window.lesJoueursDeLigue.equipe[b].joueur[a].nomJoueur.toLowerCase()+" --  "+str);
							if (window.lesJoueursDeLigue.equipe[b].joueur[a].nomJoueur.toLowerCase().indexOf(str) >= 0) {

								$("#boiteResRecherchePres").append($('<div></div>').text(window.lesJoueursDeLigue.equipe[b].joueur[a].nomJoueur).hover(function() {
									$(this).css("background", "#AAAAAA");
								}, function() {
									$(this).css("background", "#FFFFFF");
								}).click({
									equipeId : equipeId,
									id : lesJoueursDeLigue.equipe[b].joueur[a].joueurId,
									souscode : souscode
								}, function(event) {
									setPresence(event.data.equipeId, event.data.id, souscode);

									//document.location.href = "/zstats/statsjoueur.html?joueurId=" + event.data.id;
								}));

							}
						}
					}
				}
			}

			function setPresence(equipeId, joueurId, souscode) {

				var requete_ajax = new XMLHttpRequest();

				var url = "/scriptsphp/setGenerique.php";
				if (souscode > -1) {
					var valeur = {
						match_event_id : window.matchID,
						equipe_event_id : equipeId,
						joueur_event_ref : joueurId,
						code : 3,
						souscode : souscode,
						chrono : (new Date()).getTime(),
						noSequence : 0
					};
					var strTable = "table=TableEvenement0";
					var strValeur = "valeur=" + JSON.stringify(valeur);
					var strMode = "mode=creer";
					params = strTable + '&' + strValeur + '&' + strMode;

				} else {
					critere = " match_event_id='" + window.matchID + "' AND joueur_event_ref='" + joueurId + "' AND code=3";

					var strTable = "table=TableEvenement0";
					var strCritere = "critere=" + critere;
					var strMode = "mode=efface";
					params = strTable + '&' + strCritere + '&' + strMode;

				}

				requete_ajax.open('POST', url, true);
				requete_ajax.setRequestHeader("Content-type", "application/x-www-form-urlencoded");
				requete_ajax.setRequestHeader("Content-length", params.length);
				requete_ajax.setRequestHeader("Connection", "close");

				requete_ajax.onreadystatechange = function() {//Call a function when the state changes.
					if (requete_ajax.readyState == 4 && requete_ajax.status == 200) {
						//console.log("WAIT FOR SHADOW!!");
						recalculeUnMatch();
						//						window.location.reload(true);
					}
				};
				requete_ajax.send(params);

			}

			function recalculeUnMatch() {
				var requete_ajax = new XMLHttpRequest();
				var url = "/scriptsphp/calculeUnMatch.php";
				var params = "noMatchId=" + infoMatch.noMatchId;
				requete_ajax.open("POST", url, true);

				//Send the proper header information along with the request
				requete_ajax.setRequestHeader("Content-type", "application/x-www-form-urlencoded");
				requete_ajax.setRequestHeader("Content-length", params.length);
				requete_ajax.setRequestHeader("Connection", "close");

				requete_ajax.send(params);
				requete_ajax.onreadystatechange = function() {
					if (requete_ajax.readyState == 4 && requete_ajax.status == 200) {
						//console.log("WAIT!");
						getInfoMatch(infoMatch.matchId);
						//                        window.location.href = '/zstats/match.html?match=' + encodeURIComponent(window.matchID) + '&onglet=1' + '&m=' + window.m;
						// window.location.reload(true);
					}
				};

				//  console.log(requete_ajax.responseText);
				//  console.log("params: "+params);
				return requete_ajax.responseText;

			}

			function setMAJBut(strMAJ)// id est le username.
			{
				var requete_ajax = new XMLHttpRequest();
				var url = "/stats2/setMAJBut.php";
				var params = "strMAJ=" + strMAJ;
				requete_ajax.open("POST", url, true);

				//Send the proper header information along with the request
				requete_ajax.setRequestHeader("Content-type", "application/x-www-form-urlencoded");
				requete_ajax.setRequestHeader("Content-length", params.length);
				requete_ajax.setRequestHeader("Connection", "close");

				requete_ajax.send(params);
				requete_ajax.onreadystatechange = function() {
					if (requete_ajax.readyState == 4 && requete_ajax.status == 200) {
						//console.log("WAIT!");7
						recalculeUnMatch();
						//						window.location.href = '/zstats/match.html?match=' + encodeURIComponent(window.matchID) + '&onglet=1' + '&m=' + window.m;
						// window.location.reload(true);
					}
				};

				//  console.log(requete_ajax.responseText);
				//  console.log("params: "+params);
				return requete_ajax.responseText;
			}
			
            function setMAJPun(strMAJ)// id est le username.
            {
                var requete_ajax = new XMLHttpRequest();
                var url = "/stats2/setMAJPun.php";
                var params = "strMAJ=" + strMAJ;
                requete_ajax.open("POST", url, true);

                //Send the proper header information along with the request
                requete_ajax.setRequestHeader("Content-type", "application/x-www-form-urlencoded");
                requete_ajax.setRequestHeader("Content-length", params.length);
                requete_ajax.setRequestHeader("Connection", "close");

                requete_ajax.send(params);
                requete_ajax.onreadystatechange = function() {
                    if (requete_ajax.readyState == 4 && requete_ajax.status == 200) {
                        recalculeUnMatch();
                    }
                };
                return requete_ajax.responseText;
            }

			

			function setMAJFus(strMAJ)// id est le username.
			{
				var requete_ajax = new XMLHttpRequest();
				var url = "/stats2/setMAJFus.php";
				var params = "strMAJ=" + strMAJ;
				requete_ajax.open("POST", url, true);

				//Send the proper header information along with the request
				requete_ajax.setRequestHeader("Content-type", "application/x-www-form-urlencoded");
				requete_ajax.setRequestHeader("Content-length", params.length);
				requete_ajax.setRequestHeader("Connection", "close");

				requete_ajax.send(params);
				requete_ajax.onreadystatechange = function() {
					if (requete_ajax.readyState == 4 && requete_ajax.status == 200) {
						//console.log("WAIT!");
						recalculeUnMatch();
						//                        window.location.href = '/zstats/match.html?match=' + encodeURIComponent(window.matchID) + '&onglet=0' + '&m=' + window.m;
						// window.location.reload(true);
					}
				};

				//  console.log(requete_ajax.responseText);
				//  console.log("params: "+params);
				return requete_ajax.responseText;
			}

