			function faitOngletSysteme(noMatchId, arenaId) {

				$.ajax({
					url : "/scriptsphp/getAppareilsAbonne.php",
					type : "POST",

					data : jQuery.param({
						matchId : noMatchId,
						userId : window.userId,
						arenaId : arenaId
					}),
					contentType : 'application/x-www-form-urlencoded; charset=UTF-8',
					success : function(response) {
						var laTable = eval("(" + response + ")");
						// console.log(laTable.cams);
						// console.log(laTable.remotes);
						if (laTable.cams != null) {
							var table = $.makeTable(laTable.cams);
							(table).appendTo("#Systeme");
						}
						if (laTable.remotes != null) {
							var table2 = $.makeTable(laTable.remotes);
							(table2).appendTo("#Systeme");
						}
					},
					error : function(xhr, status, error) {
						var err = eval("(" + xhr.responseText + ")");
						console.log(err.Message + "  --  ereur gardMax");
					}
				});

			}


			$.makeTable = function(mydata) {
				var table = $('<table border=1>');
				var tblHeader = "<tr>";
				for (var k in mydata[0])
				tblHeader += "<th>" + k + "</th>";
				tblHeader += "</tr>";
				$(tblHeader).appendTo(table);
				$.each(mydata, function(index, value) {
					var TableRow = $("<tr></tr>");
					$.each(value, function(key, val) {

						$(TableRow).append($("<td></td>").text(val));
						if (key == "telId") {

							if (index % 2 == 0) {
								$(TableRow).addClass("lignePaire");
							} else {
								$(TableRow).addClass("ligneImpaire");
							}

						}
					});
					$(table).append(TableRow);

				});
				return ($(table));
			};
			
