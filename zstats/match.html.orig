			function getInfoVid(vidIndex, mBut) {
				//console.log("getInfoVid "+videofile);

				var place = mBut.video[vidIndex].emplacement;
				if (place == null || !strcmp(place, "")) {
                                        place = "syncstats.com";
                                       // document.getElementsByTagName('SOURCE')[0].src = "../lookatthis/" + event.data.mBut.video[0].fic;

                                    }
                                     /*else {
                                        document.getElementsByTagName('SOURCE')[0].src = "http://" + place + "/lookatthis/" + event.data.mBut.video[0].fic;
                                    }
                                    //console.log(document.getElementsByTagName('SOURCE')[0].src );
                                    //document.getElementsByTagName('SOURCE')[0].src = "http://"+place+"/lookatthis/" + mBut.video[0].fic;
                                    document.getElementsByTagName('SOURCE')[0].type = "video/mp4";
*/
				if ((navigator.userAgent.indexOf('iPhone') != -1) || (navigator.userAgent.indexOf('iPod') != -1) || (navigator.userAgent.indexOf('iPad') != -1)) {
					//console.log($('source').attr('src'));

					document.location = "http://" + place + "/lookatthis/" + mBut.video[vidIndex].fic;
				}
				
				
				
				$('#parent-erreur').remove();
				//$('#contVids').show();
				$('#media-video').videoPlayer({
					'playerWidth' : 1,
					'videoClass' : 'video'
				});
