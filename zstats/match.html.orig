			function afficheEtoiles() {

				div1 = document.getElementById('tabEtoiles');

				if (window.infoMatch.cleValeur.etoile1 != undefined) {

					joueur1 = "";

					for (var a = 0; a < window.statsJSONHome.joueurs.length; a++) {

						if (window.statsJSONHome.joueurs[a].joueurId == window.infoMatch.cleValeur.etoile1) {
							joueur1 = window.statsJSONHome.joueurs[a].nom;
						}
					}
					if (joueur1.length < 1) {
						for (var a = 0; a < window.statsJSONVis.joueurs.length; a++) {
							if (window.statsJSONVis.joueurs[a].joueurId == window.infoMatch.cleValeur.etoile1) {
								joueur1 = window.statsJSONVis.joueurs[a].nom;
							}
						}
					}

					p1 = document.createElement('P');
					p1.innerHTML = "&#9734 - " + joueur1;
					if (joueur1.length > 0)
						div1.appendChild(p1);

				}
				if (window.infoMatch.cleValeur.etoile2 != undefined) {

					joueur2 = "";
					for (var a = 0; a < window.statsJSONHome.joueurs.length; a++) {
						if (window.statsJSONHome.joueurs[a].joueurId == window.infoMatch.cleValeur.etoile2) {
							joueur2 = window.statsJSONHome.joueurs[a].nom;
						}
					}
					if (joueur2.length < 1) {
						for (var a = 0; a < window.statsJSONVis.joueurs.length; a++) {
							if (window.statsJSONVis.joueurs[a].joueurId == window.infoMatch.cleValeur.etoile2) {
								joueur2 = window.statsJSONVis.joueurs[a].nom;
							}
						}
					}
					p2 = document.createElement('P');
					p2.innerHTML = "&#9734 &#9734  - " + joueur2;
					if (joueur2.length > 0)
						div1.appendChild(p2);

				}
				if (window.infoMatch.cleValeur.etoile3 != undefined) {
					joueur3 = "";
					for (var a = 0; a < window.statsJSONHome.joueurs.length; a++) {
						if (window.statsJSONHome.joueurs[a].joueurId == window.infoMatch.cleValeur.etoile3) {
							joueur3 = window.statsJSONHome.joueurs[a].nom;
						}
					}
					if (joueur3.length < 1) {
						for (var a = 0; a < window.statsJSONVis.joueurs.length; a++) {
							if (window.statsJSONVis.joueurs[a].joueurId == window.infoMatch.cleValeur.etoile3) {
								joueur3 = window.statsJSONVis.joueurs[a].nom;
							}
						}
					}
					p3 = document.createElement('P');
					p3.innerHTML = "&#9734 &#9734 &#9734 - " + joueur3;
					if (joueur3.length > 0)
						div1.appendChild(p3);
				}

			}

			function selectOnglet(a) {
				for (var b = 0; b < window.vecTab.length; b++) {
					if (a == b) {
					    $('#'+window.vecTab[a]).show();
						 $('#'+'dTitre_' + a).addClass("active");
					} else {
                        $('#'+window.vecTab[b]).hide();
                         $('#'+'dTitre_' + b).removeClass("active");
					}
				}

			}

