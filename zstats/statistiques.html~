			function discrFiche(a, b) {

				ficheA = 0;
				ficheB = 0;
				strFiche = "";

				if (window.matchsDsSaison != undefined) {
					duels = new Array();
					for (var d = 0; d < window.matchsDsSaison.matchs.length; d++) {
						if ((window.matchsDsSaison.matchs[d].eqDomId == a.id && window.matchsDsSaison.matchs[d].eqVisId == b.id) || (window.matchsDsSaison.matchs[d].eqDomId == b.id && window.matchsDsSaison.matchs[d].eqVisId == a.id)) {
							duels.push(window.matchsDsSaison.matchs[d]);
						}
					}
					for (var e = 0; e < duels.length; e++) {
						if (duels[e].eqDomId == a.id) {
							if (parseInt(duels[e].equipeScoreDom) >= parseInt(duels[e].equipeScoreVis)) {
								if (duels[e].equipeScoreDom != duels[e].equipeScoreVis) {
									ficheA++;
									ficheA++;
								} else {
									ficheA++;
									ficheB++;
								}
							} else {
								ficheB++;
								ficheB++;
							}
							strFiche += duels[e].eqDom + ": " + duels[e].equipeScoreDom + " - " + duels[e].eqVis + ": " + duels[e].equipeScoreVis + " fiche A-B:" + ficheA + ficheB + "\n";
						}
						if (duels[e].eqVisId == a.id) {
							if (parseInt(duels[e].equipeScoreVis) >= parseInt(duels[e].equipeScoreDom)) {
								if (duels[e].equipeScoreVis != duels[e].equipeScoreDom) {
									ficheA++;
									ficheA++;
								} else {
									ficheA++;
									ficheB++;
								}
							} else {
								ficheB++;
								ficheB++;
							}
							strFiche += duels[e].eqDom + ": " + duels[e].equipeScoreDom + " - " + duels[e].eqVis + ": " + duels[e].equipeScoreVis + " fiche A-B:" + ficheA + ficheB + "\n";
						}
					}
					//		alert("fiche B:"+ficheB+" , ficheA: "+ficheA);
					//	alert(strFiche);

				}
				return ficheB - ficheA;
			}
			
