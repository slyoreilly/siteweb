			function extirpeSaison(id) {
				//			alert(window.vecEquipe.equipes.length);
				
				if (parseInt(window.ligueId) == 49 || parseInt(window.ligueId) == 50 || parseInt(window.ligueId) == 51) {

					var k = 0;
					while (k < window.window.cJSON.customClassement.saisons.length) {
					//					alert(window.vecEquipe.equipes.equipeId);
						if (id == window.window.cJSON.customClassement.saisons[k].saisonId) {
							return k;
						}
						k++;
					}
				} else {
					var k = 0;
